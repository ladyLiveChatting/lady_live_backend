# Production — copy keys to Railway Variables (do not commit real secrets).
# Railway usually sets NODE_ENV=production automatically.

NODE_ENV=production

# Use Variable reference from MySQL service, e.g. ${{MySQL.MYSQL_URL}} or MYSQL_PRIVATE_URL
DATABASE_URL=

JWT_SECRET=
JWT_REFRESH_SECRET=

AGORA_APP_ID=
AGORA_APP_CERTIFICATE=

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
