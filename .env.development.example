# Local development — copy to `.env.development` (gitignored) or keep using `.env`.
NODE_ENV=development

DATABASE_URL=mysql://root:root@127.0.0.1:3306/meet_connect

JWT_SECRET=dev-jwt-secret-change-in-production
JWT_REFRESH_SECRET=dev-refresh-secret-change-in-production

# Boy wallet top-up packages: coins:priceInr pairs, comma-separated.
WALLET_COIN_PACKAGES=100:99,500:449,1200:999,2500:1999

AGORA_APP_ID=
AGORA_APP_CERTIFICATE=

# Boys + girls Firebase Admin SDK JSON paths (files live in backend/, gitignored)
FIREBASE_SERVICE_ACCOUNT_PATH=./boys-dating-application-firebase-adminsdk-fbsvc-cbeb338f85.json
FIREBASE_GIRLS_SERVICE_ACCOUNT_PATH=./girls-dating-application-firebase-adminsdk-fbsvc-06b69d4453.json
PUSH_API_SECRET=change-me-push-secret
PUBLIC_API_BASE_URL=https://ladylive-production.up.railway.app
PUSH_NOTIFICATION_IMAGE_URL=https://ladylive-production.up.railway.app/static/push-notification.png
# Razorpay credentials
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Cloudflare R2 (profile photos — apply CORS: r2-cors.dashboard.example.json)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=
