PORT=3000

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=root
DB_DATABASE=meet_connect

# Optional: set this to skip composing from DB_* above
# DATABASE_URL="mysql://root:root@127.0.0.1:3306/meet_connect"

JWT_SECRET="change-me-to-a-long-random-string"
JWT_REFRESH_SECRET="change-me-refresh-secret"

# Boy wallet top-up packages: coins:priceInr pairs, comma-separated (until payment gateway).
WALLET_COIN_PACKAGES="100:99,500:449,1200:999,2500:1999"

# Agora (Video/Voice SDK — RTC token minting). Get from Agora Console.
AGORA_APP_ID=""
AGORA_APP_CERTIFICATE=""
# Optional TTLs (seconds), max 86400
# AGORA_TOKEN_TTL_SEC=3600
# AGORA_PRIVILEGE_TTL_SEC=3600

# Firebase Cloud Messaging — boys app (project: boys-dating-application)
# Path to Firebase Admin SDK JSON (never commit this file).
FIREBASE_SERVICE_ACCOUNT_PATH="./boys-dating-application-firebase-adminsdk-fbsvc-cbeb338f85.json"
# Firebase Cloud Messaging — girls app (project: girls-dating-application)
FIREBASE_GIRLS_SERVICE_ACCOUNT_PATH="./girls-dating-application-firebase-adminsdk-fbsvc-06b69d4453.json"
# Secret for POST /notifications/push/boys and /notifications/push/girls (header: X-Push-Api-Secret)
PUSH_API_SECRET="change-me-push-secret"
# Base URL phones can open (local LAN IP or production host)
PUBLIC_API_BASE_URL="https://ladylive-production.up.railway.app"
PUSH_NOTIFICATION_IMAGE_URL="https://ladylive-production.up.railway.app/static/push-notification.png"

# Cloudflare R2 (S3 API — Manage R2 API Tokens, not cfat_/cfut_ Wrangler tokens)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=
# Optional; default https://{R2_ACCOUNT_ID}.r2.cloudflarestorage.com
# R2_ENDPOINT=
# R2_PRESIGN_EXPIRES_SECONDS=3600
