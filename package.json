{
  "name": "meet-connect-api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "postinstall": "prisma generate",
    "build": "nest build",
    "start": "nest start",
    "start:dev": "NODE_ENV=development nest start --watch",
    "start:debug": "nest start --debug 0.0.0.0:9229 --watch",
    "start:prod": "NODE_ENV=production node dist/main.js",
    "start:railway": "NODE_ENV=production node scripts/prisma-deploy.cjs && NODE_ENV=production node dist/main.js",
    "db:create": "node scripts/create-db.cjs",
    "db:setup": "npm run db:create && npm run prisma:generate && npm run prisma:push",
    "db:reset": "node scripts/reset-db.cjs",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "node -r ./scripts/prisma-env.cjs node_modules/.bin/prisma migrate dev",
    "prisma:push": "node -r ./scripts/prisma-env.cjs node_modules/.bin/prisma db push",
    "prisma:deploy": "node scripts/prisma-deploy.cjs",
    "prisma:studio": "node -r ./scripts/prisma-env.cjs node_modules/.bin/prisma studio"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1051.0",
    "@aws-sdk/s3-request-presigner": "^3.1051.0",
    "@nestjs/common": "^11.1.19",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^7.5.5",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.19",
    "@nestjs/platform-socket.io": "^7.6.18",
    "@nestjs/swagger": "^11.4.2",
    "@nestjs/websockets": "^7.6.18",
    "@prisma/client": "^5.22.0",
    "agora-token": "^2.0.5",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^16.4.7",
    "firebase-admin": "^14.1.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "prisma": "^5.22.0",
    "razorpay": "^2.9.6",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.1",
    "uuid": "^11.0.3"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.1.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "@types/passport-jwt": "^4.0.1",
    "@types/uuid": "^10.0.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.2"
  }
}
