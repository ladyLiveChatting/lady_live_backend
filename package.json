{
  "name": "meet-connect-api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "postinstall": "prisma generate",
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug 0.0.0.0:9229 --watch",
    "start:prod": "node dist/main.js",
    "db:create": "node scripts/create-db.cjs",
    "db:setup": "npm run db:create && npm run prisma:generate && npm run prisma:push",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "node -r ./scripts/prisma-env.cjs node_modules/.bin/prisma migrate dev",
    "prisma:push": "node -r ./scripts/prisma-env.cjs node_modules/.bin/prisma db push",
    "prisma:studio": "node -r ./scripts/prisma-env.cjs node_modules/.bin/prisma studio"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/platform-socket.io": "^10.4.15",
    "@nestjs/swagger": "^7.4.2",
    "@nestjs/websockets": "^10.4.15",
    "@prisma/client": "^5.22.0",
    "agora-token": "^2.0.5",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^16.4.7",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.1",
    "uuid": "^11.0.3"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "@types/passport-jwt": "^4.0.1",
    "@types/uuid": "^10.0.0",
    "prisma": "^5.22.0",
    "typescript": "^5.7.2"
  }
}
