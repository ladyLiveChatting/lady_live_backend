generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  BOY
  GIRL
  GUEST
}

enum CallStatus {
  REQUESTED
  ACCEPTED
  REJECTED
  ENDED
  CANCELLED
}

enum WalletTxType {
  CREDIT
  DEBIT
}

model User {
  id           String   @id @default(cuid())
  email        String?  @unique
  phone        String?  @unique
  passwordHash String?
  role         UserRole
  isGuest      Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  refreshTokens RefreshToken[]
  profile       Profile?
  wallet        Wallet?
  sentMessages  Message[]                 @relation("MessageSender")
  callsAsCaller Call[]                    @relation("Caller")
  callsAsCallee Call[]                    @relation("Callee")
  participants  ConversationParticipant[]
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Profile {
  userId         String    @id
  displayName    String
  bio            String?   @db.Text
  age            Int?
  country        String?
  imageUrl       String?
  /// Per-minute rate for girls (callers pay in coins); ignored for boys/guests in UI
  coinsPerMinute Int       @default(60)
  isOnline       Boolean   @default(false)
  lastSeenAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Wallet {
  userId    String              @id
  balance   Int                 @default(0)
  updatedAt DateTime            @updatedAt
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  txs       WalletTransaction[]
}

model WalletTransaction {
  id        String       @id @default(cuid())
  walletId  String
  amount    Int
  type      WalletTxType
  note      String?
  refCallId String?
  createdAt DateTime     @default(now())
  wallet    Wallet       @relation(fields: [walletId], references: [userId], onDelete: Cascade)

  @@index([walletId])
}

model Conversation {
  id        String                    @id @default(cuid())
  createdAt DateTime                  @default(now())
  updatedAt DateTime                  @updatedAt
  messages  Message[]
  members   ConversationParticipant[]
}

model ConversationParticipant {
  conversationId String
  userId         String
  joinedAt       DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([conversationId, userId])
  @@index([userId])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  senderId       String
  body           String       @db.Text
  readAt         DateTime?
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([senderId])
}

model Call {
  id                        String     @id @default(cuid())
  callerId                  String
  calleeId                  String
  status                    CallStatus @default(REQUESTED)
  requestedAt               DateTime   @default(now())
  acceptedAt                DateTime?
  endedAt                   DateTime?
  durationSeconds           Int?
  /// Coins deducted from the boy (boosted per-minute rate × charged minutes).
  coinsSpent                Int?
  girlBaseCoinsPerMinute    Int?
  boysVisibleCoinsPerMinute Int?
  chargedMinutes            Int?
  coinsGirlGross            Int?
  coinsCompanyDeduction     Int?
  coinsGirlFinal            Int?
  caller                    User       @relation("Caller", fields: [callerId], references: [id], onDelete: Cascade)
  callee                    User       @relation("Callee", fields: [calleeId], references: [id], onDelete: Cascade)

  @@index([callerId])
  @@index([calleeId])
}
